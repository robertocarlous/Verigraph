# Copy to .env and fill in. Nothing here is required just to run
# `npm test` or `npm run dev` (the server boots and /v1/health + /v1/pricing
# work with zero config — see README).

# ── OKX OnchainOS API credentials (public/HMAC tier) ────────────────────────
# Apply at the OKX Developer Portal. Used for the public dex-history endpoint
# (restClient.ts) AND as the CLI's own headless AK login identity (authManager.ts).
OKX_API_KEY=
OKX_SECRET_KEY=
OKX_PASSPHRASE=

# Override only if OKX tells you to use a different gateway (defaults to the
# same https://web3.okx.com the reference onchainos CLI uses).
# OKX_BASE_URL=

# Path to the `onchainos` CLI binary if it's not on PATH.
# ONCHAINOS_CLI_BIN=onchainos

# X Layer chainIndex for OKX dex-history calls. Confirmed live: 1952 (testnet)
# is REJECTED by this endpoint (chain id param error) — mainnet-only, since
# there is no real DEX market data on a testnet. Default "196" = mainnet.
# CHAIN_INDEX=196

# ── x402 payment gate (self-facilitated EIP-3009) ───────────────────────────
# Get the CURRENT X Layer testnet RPC URL from X Layer's official docs /
# Chainlist — OKX's own onchainos CLI does not hardcode one (only mainnet,
# 196 -> https://rpc.xlayer.tech, is wired in their source), so don't guess.
XLAYER_TESTNET_RPC_URL=

# Private key of the relayer wallet that broadcasts settlement transactions
# (transferWithAuthorization). Needs a small amount of native gas token, but
# X Layer is gas-free, so in practice this can be nearly empty.
RELAYER_PRIVATE_KEY=

# The address that receives payment (can be the relayer's own address, or a
# separate treasury wallet).
SERVICE_WALLET_ADDRESS=

# Set automatically by `npm run deploy:demo-token` (writes .deployed-token.json),
# or set explicitly here to skip reading that file.
# DEMO_TOKEN_ADDRESS=
# DEMO_TOKEN_NAME=Verigraph Demo USD
# DEMO_TOKEN_VERSION=1
# DEMO_TOKEN_DECIMALS=6

# Price per integrity-check query, in the demo token's atomic units.
# Default 10000 = 0.01 vUSD at 6 decimals.
# PRICE_ATOMIC_UNITS=10000
# PAYMENT_MAX_TIMEOUT_SECONDS=120

# Only needed for scripts/deployDemoToken.ts (a separate, funded deployer key —
# can be the same as RELAYER_PRIVATE_KEY for the demo).
# DEMO_TOKEN_DEPLOYER_PRIVATE_KEY=
# DEMO_WALLET_A_ADDRESS=
# DEMO_WALLET_B_ADDRESS=
# DEMO_MINT_AMOUNT=1000

# ── Detection engine tuning (optional) ──────────────────────────────────────
# INTEGRITY_CHECK_WINDOW_DAYS=90
# ONCHAIN_LOOKBACK_BLOCKS=50000
# PORT=8402

# ── Self-play harness (selfplay/transferLoop.ts) ────────────────────────────
# Two SEPARATE OKX AK identities — each is one of the two "colluding" agents.
WALLET_A_OKX_API_KEY=
WALLET_A_OKX_SECRET_KEY=
WALLET_A_OKX_PASSPHRASE=
WALLET_B_OKX_API_KEY=
WALLET_B_OKX_SECRET_KEY=
WALLET_B_OKX_PASSPHRASE=
# WALLET_A_ONCHAINOS_HOME=.onchainos-wallet-a
# WALLET_B_ONCHAINOS_HOME=.onchainos-wallet-b
# SELF_PLAY_CHAIN=xlayer_test
# SELF_PLAY_ITERATIONS=6
# Confirmed live: an individual account's `wallet send` on X Layer testnet
# reliably succeeds once, then fails "may_be_out_of_gas" (a misleading error —
# balance is fine) on a second send shortly after — looks like a real OKX
# testnet smart-account/bundler rate-limit or slow state-propagation issue,
# not a Verigraph bug (the script retries with backoff and continues past
# per-iteration failures rather than aborting). If you want all N iterations
# to complete, try a much longer interval (minutes, not seconds) to stay
# outside whatever cooldown window this is.
# SELF_PLAY_INTERVAL_MS=30000
# SELF_PLAY_AMOUNT=0.01
# EXPLORER_BASE_URL=

# ── scripts/registerAsp.ts (one-time admin script, not used by the server) ──
# ASP_NAME=
# ASP_DESCRIPTION=
# ASP_AVATAR_PATH=
# ASP_SERVICE_NAME=
# ASP_SERVICE_DESCRIPTION=
# ASP_SERVICE_TYPE=A2MCP
# ASP_SERVICE_FEE=
# ASP_SERVICE_ENDPOINT=
# ASP_CONSENT_KEY=
# ASP_AUTO_ACTIVATE=true
